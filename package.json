{
  "name": "lumina",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm --workspace @lumina/desktop run dev",
    "dev:gateway": "npm --workspace @lumina/gateway run dev",
    "build": "npm --workspaces run build",
    "typecheck": "npm --workspaces run typecheck"
  }
}

